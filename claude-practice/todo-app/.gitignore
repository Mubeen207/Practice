# Root gitignore for Todo App project

# Dependencies
node_modules/
*/node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.*.local
*/.env
*/.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.tmproj
*.esproj

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Build outputs
dist/
build/
out/
.next/

# Coverage reports
coverage/
.nyc_output/

# Debug files
.node_inspect*

# Local history
.history/

# Misc
*.bak
*.orig
*.save
